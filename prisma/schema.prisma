// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("admin") // admin, editor, viewer
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  metaTitle     String?
  metaDescription String?
  status        String    @default("draft") // published, draft
  language      String    @default("en") // en, ar
  sections      String?   // JSON string of sections (legacy)
  builderData   String?   // JSON array of builder section configurations
  isBuilderPage Boolean   @default(false) // Flag for builder-created pages
  builderVersion String?  // Track builder version for migrations
  isHomepage    Boolean   @default(false) // Flag for homepage
  
  // Multilingual grouping
  pageGroupId   String?   // Link to PageGroup for multilingual pages
  isDefaultLang Boolean   @default(false) // Is this the default language version?
  lastSyncedAt  DateTime? // Last time structure was synced from default
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  pageGroup     PageGroup? @relation(fields: [pageGroupId], references: [id], onDelete: SetNull)
  
  @@index([pageGroupId])
  @@index([language])
  @@index([status])
}

model PageGroup {
  id              String   @id @default(cuid())
  name            String   // Display name (e.g., "Home Page")
  slug            String   @unique // Common slug without language prefix (e.g., "home")
  defaultLanguage String   @default("en") // Default language for this group
  
  pages           Page[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Translation {
  id        String   @id @default(cuid())
  key       String
  language  String   // en, ar
  value     String
  namespace String?  // components, pages, nav, etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, language, namespace])
}

model Media {
  id        String   @id @default(cuid())
  filename  String
  path      String
  altText   String?
  fileSize  Int
  mimeType  String
  createdAt DateTime @default(now())
}

model SectionTemplate {
  id           String   @id @default(cuid())
  name         String
  type         String   // hero, features, cta, etc.
  category     String   // Headers, Content, Actions, etc.
  description  String
  defaultData  String   // JSON string
  usageCount   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Menu {
  id        String   @id @default(cuid())
  name      String   // Main Menu, Footer Menu, etc.
  location  String   // header, footer, sidebar
  language  String   @default("en")
  items     String   // JSON array of menu items
  status    String   @default("active") // active, inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([location, language])
}

model SiteSettings {
  id        String   @id @default(cuid())
  data      String   // JSON string of all settings
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Footer {
  id              String   @id @default(cuid())
  language        String   @default("en") // en, ar, tr, fr, de, es
  companyName     String
  tagline         String?
  description     String?
  contactInfo     String?  // JSON: { show, email, phone, address }
  columns         String   // JSON array of footer columns with links
  bottomBar       String?  // JSON: { show, copyrightText, showSocialLinks, socialLinks }
  style           String?  // JSON: { backgroundColor, textColor, linkColor, borderColor, padding }
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([language])
  @@index([language])
  @@index([isActive])
}